{
  "name": "MoltPe Agent Payments",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "cd mcp-server && npm install && cd ../x402-client && npm install",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  },
  "postStartCommand": "cd mcp-server && npm start &"
}
